DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/brandqoai
JWT_SECRET=change-me-in-production
PORT=4000
CORS_ORIGIN=http://localhost:3000

# WhatsApp Business Cloud API (set these in real deployments)
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-long-lived-access-token

# AI content generation
# AI_PROVIDER=fallback
# CONTENT_TEXT_MODEL=
# CONTENT_IMAGE_MODEL=
# Optional override; image generation also runs when CONTENT_IMAGE_MODEL is set.
# ENABLE_IMAGE_GENERATION=false

# Claude text generation
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Mistral-compatible text generation through Together AI
# TOGETHER_API_KEY=
# TOGETHER_TEXT_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Optional image generation through Replicate
# REPLICATE_API_KEY=
