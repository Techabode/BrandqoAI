DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/brandqoai
JWT_SECRET=change-me-in-production
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development # change to "production" during deployment

# WhatsApp Business Cloud API (set these in real deployments)
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-long-lived-access-token

# AI Providers (required for content generation)
# AI_PROVIDER can be "mistral" (default, cheaper) or "claude" (premium)
AI_PROVIDER=mistral

# Mistral 7B via Together AI (~$0.003 per 1K tokens)
# Required if AI_PROVIDER=mistral
TOGETHER_API_KEY=your-together-ai-api-key

# Claude Sonnet via Anthropic
# Required if AI_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: override the default Claude model if needed
ANTHROPIC_MODEL=claude-sonnet-4-6

# Stable Diffusion image generation (optional, used for image prompts)
REPLICATE_API_KEY=your-replicate-api-key

# Meta OAuth (Facebook / Instagram account linking)
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# META_REDIRECT_URI=http://localhost:4000/api/social/meta/callback
# META_GRAPH_API_VERSION=v22.0
# SOCIAL_OAUTH_STATE_SECRET=change-me-too

# App URLs used for browser handoff
# APP_URL=http://localhost:3000
# BACKEND_PUBLIC_URL=http://localhost:4000
